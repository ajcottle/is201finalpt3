<!DOCTYPE html>
<html>
<head>
  <title>Scratch Page</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

<h1 id="top">My Topic</h1>

<!-- anchor link -->
<a href="#bottom">Go to bottom</a>

<!-- nested list -->
<ol>
  <li>Main item
    <ul>
      <li>Sub item</li>
    </ul>
  </li>
</ol>

<!-- image -->
<img src="your-image.jpg" width="300">

<!-- YouTube embed -->
<iframe width="560" height="315"
src="https://www.youtube.com/embed/VIDEO_ID"
frameborder="0" allowfullscreen>
</iframe>

<!-- divs -->
<div class="box1">Content</div>
<div class="box2">Content</div>
<div class="box3">Content</div>

<!-- Tableau (you’ll paste embed code later) -->
<div>
  Tableau graph here
</div>

<a id="bottom"></a>
<a href="index.html">Back to Home</a>

</body>
</html>